      "blocking_questions": [
        "Confirm real copy for: brand_name",
        "Confirm real copy for: product_categories"
      ],
      "facts": [
        {
          "id": "brand_name",
          "status": "placeholder"
        },
        {
          "id": "product_categories",
          "status": "placeholder"
        },
        {
          "id": "shop_cta",
          "status": "placeholder"
        },
        {
          "id": "trust_signals",
          "status": "placeholder"
        }
      ]
    },
    "page_intent": {
      "page_type": "landing",
      "conversion_goal": "trust_signals",
      "audience": "ecommerce"
    },
    "native_policy": {
      "strict": false,
      "block_html_widgets": true,
      "require_native_gap_for_custom_css": true,
      "enforce_heading_hierarchy": true
    },
    "verification_policy": {
      "structural_readback": true,
      "responsive_breakpoints": [
        "desktop",
        "tablet",
        "mobile"
      ],
      "contrast_check": true,
      "rollback_on_failure": true
    }
  },
  "version": "2.0.0",
  "page_type": "landing",
  "required_content_facts": [
    "brand_name",
    "product_categories",
    "shop_cta",
    "trust_signals"
  ],
  "engine_compatibility": {
    "elementor": true,
    "gutenberg": true,
    "fse": true,
    "notes": {
      "elementor": "Native containers + widgets; layout intent via align_items/justify_content/fullWidth.",
      "gutenberg": "core/group constrained layout; separators map to core/separator.",
      "fse": "Constrained template/page markup via FseTransactionQueue; no Elementor meta."
    }
  },
  "accessibility_intent": {
    "target": "wcag-2.2-aa",
    "contrast_pairs": [
      "text/background",
      "primary/background"
    ],
    "heading_hierarchy": true,
    "landmarks": true
  }
}
