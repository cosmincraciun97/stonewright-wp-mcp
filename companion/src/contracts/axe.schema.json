{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stonewright.dev/companion/contracts/axe",
  "title": "Axe a11y contract",
  "description": "POST /axe — axe-core accessibility audit. Design decisions: (1) endpoint is named /axe (not /a11y) per plan; (2) URL comes from PHP.",
  "type": "object",
  "properties": {
    "request": { "$ref": "#/$defs/AxeRequest" },
    "response": { "$ref": "#/$defs/AxeResponse" }
  },
  "$defs": {
    "AxeViolation": {
      "type": "object",
      "properties": {
        "rule":   { "type": "string" },
        "impact": { "type": "string", "enum": ["minor", "moderate", "serious", "critical"] },
        "help":   { "type": "string" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "html":   { "type": "string" },
              "target": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          }
        }
      },
      "required": ["rule", "impact", "help", "nodes"],
      "additionalProperties": true
    },
    "AxeRequest": {
      "type": "object",
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "url": {
          "type": "string",
          "pattern": "^https?://",
          "description": "Target URL resolved by PHP."
        },
        "ruleset": {
          "type": "string",
          "enum": ["wcag2a", "wcag2aa", "wcag2aaa", "wcag21a", "wcag21aa", "best-practice"],
          "default": "wcag2aa"
        }
      },
      "required": ["request_id", "url"],
      "additionalProperties": false
    },
    "AxeResponse": {
      "type": "object",
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/AxeViolation" }
        },
        "passes_count": {
          "type": "integer",
          "minimum": 0
        },
        "incomplete_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["request_id", "violations", "passes_count"],
      "additionalProperties": false
    }
  }
}
