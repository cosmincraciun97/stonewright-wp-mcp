{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stonewright.dev/companion/contracts/screenshot",
  "title": "Screenshot contract",
  "description": "POST /screenshot — Playwright screenshot endpoint. Design decisions: (1) URL comes from PHP-resolved permalink, companion never chooses paths; (2) artifact_path is PHP-generated via QaArtifactStore::reserve() and must match the allowed pattern; (3) request_id is generated by PHP (wp_generate_uuid4()) and echoed back.",
  "type": "object",
  "properties": {
    "request": {
      "$ref": "#/$defs/ScreenshotRequest"
    },
    "response": {
      "$ref": "#/$defs/ScreenshotResponse"
    }
  },
  "$defs": {
    "Viewport": {
      "type": "object",
      "properties": {
        "width":  { "type": "integer", "minimum": 1, "maximum": 7680 },
        "height": { "type": "integer", "minimum": 1, "maximum": 4320 }
      },
      "required": ["width", "height"],
      "additionalProperties": false
    },
    "ScreenshotRequest": {
      "type": "object",
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
          "description": "UUID v4 generated by PHP; companion echoes it back in the response."
        },
        "url": {
          "type": "string",
          "pattern": "^https?://",
          "description": "Target URL — must be an absolute http/https URL. Never a file:// or data: URL."
        },
        "artifact_path": {
          "type": "string",
          "pattern": "^/[a-z0-9/_.-]+stonewright-qa/[a-z0-9-]+/?$",
          "description": "Per-request directory reserved by PHP QaArtifactStore::reserve(). Companion rejects any path not matching this pattern."
        },
        "viewport": { "$ref": "#/$defs/Viewport" },
        "full_page": {
          "type": "boolean",
          "default": true
        },
        "wait_for": {
          "type": "string",
          "enum": ["load", "domcontentloaded", "networkidle", "commit"],
          "default": "networkidle"
        },
        "wait_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 30000,
          "default": 500
        },
        "selector": {
          "type": "string",
          "description": "CSS selector — screenshot only the matched element."
        }
      },
      "required": ["request_id", "url", "artifact_path"],
      "additionalProperties": false
    },
    "ScreenshotResponse": {
      "type": "object",
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
        },
        "artifact_id": {
          "type": "string",
          "description": "Unique identifier for this artifact (filename without extension)."
        },
        "path": {
          "type": "string",
          "description": "Absolute filesystem path to the saved PNG inside artifact_path."
        },
        "url": {
          "type": "string",
          "description": "Public URL for the screenshot (via WordPress uploads)."
        },
        "width":  { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "viewport": { "$ref": "#/$defs/Viewport" },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 timestamp."
        }
      },
      "required": ["request_id", "artifact_id", "path", "url", "width", "height", "viewport", "created_at"],
      "additionalProperties": false
    }
  }
}
