# Bearer token that callers must present to the companion HTTP server
COMPANION_BEARER_TOKEN=change-me-in-production

# Comma-separated list of allowed request origins (leave empty to allow all)
COMPANION_ALLOWED_ORIGINS=http://localhost:8888,https://example.com

# Optional HTTP bridge for advanced WordPress-side companion calls.
# Leave both unset for normal stdio MCP clients such as Antigravity, Codex, and Claude Code.
# STONEWRIGHT_HTTP_ENABLE=1
# PORT=8765

# WordPress site used by local stdio MCP clients.
# The companion derives <site>/wp-json/mcp/stonewright.
STONEWRIGHT_WP_URL=https://your-site.example.com
STONEWRIGHT_WP_USERNAME=your-wp-username
STONEWRIGHT_WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
STONEWRIGHT_MCP_TOOL_PROFILE=essential

# Optional explicit endpoint override and legacy credential aliases.
# STONEWRIGHT_MCP_URL=https://your-site.example.com/wp-json/mcp/stonewright
# WP_API_USERNAME=your-wp-username
# WP_API_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional persistent project credential store. When WP_API_PASSWORD is absent,
# the companion can reuse a saved Application Password from this file. For
# localhost/.local/.test sites it may create one through guarded WP-CLI once.
# STONEWRIGHT_CREDENTIAL_STORE=C:\Users\you\AppData\Local\Stonewright\credentials\project.json
# STONEWRIGHT_CREDENTIAL_DIR=C:\Users\you\AppData\Local\Stonewright\credentials
# STONEWRIGHT_WP_APP_PASSWORD_AUTO=local-only
# STONEWRIGHT_WP_APP_PASSWORD_NAME=Stonewright Companion

# WP-CLI executable. Defaults to `wp`.
# Set this if you have WP-CLI installed globally and want to skip phar discovery.
# STONEWRIGHT_WP_CLI_BIN=wp

# Directory where wp-cli.phar is cached by the postinstall script and auto-bootstrap.
# Defaults to %LOCALAPPDATA%\Stonewright\wp-cli (Windows) or ~/.stonewright/wp-cli
# STONEWRIGHT_WP_CLI_INSTALL_DIR=C:\Users\you\AppData\Local\Stonewright\wp-cli

# PHP binary used to run wp-cli.phar (auto-discovered from LocalWP by default).
# STONEWRIGHT_WP_CLI_PHP_BIN=php

# php.ini for WP-CLI (optional; auto-discovered from LocalWP conf/ by default).
# STONEWRIGHT_WP_CLI_PHP_INI=C:\path\to\php.ini

# Path to a pre-downloaded wp-cli.phar (overrides STONEWRIGHT_WP_CLI_INSTALL_DIR discovery).
# STONEWRIGHT_WP_CLI_PHAR_PATH=C:\path\to\wp-cli.phar

# Preferred WordPress root for WP-CLI commands.
STONEWRIGHT_WP_ROOT=C:\path\to\wordpress

# Extra comma-separated allowed roots for WP-CLI --path/cwd validation.
STONEWRIGHT_WP_ALLOWED_ROOTS=C:\path\to\wordpress,C:\path\to\staging-wordpress

# Remote MCP server to proxy requests to (optional - leave empty to disable proxy)
MCP_PROXY_TARGET=

# Bearer token for the upstream proxy target
MCP_PROXY_TOKEN=
