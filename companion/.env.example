# Figma personal access token — create at https://www.figma.com/settings under "Access tokens"
FIGMA_TOKEN=

# Base URL of your WordPress installation (no trailing slash)
STONEWRIGHT_WP_URL=https://example.com

# WordPress application password for the companion service account
# Format: "username:app-password" (base64-encoded by the auth helper)
STONEWRIGHT_WP_APP_PASSWORD=

# Bearer token that callers must present to the companion HTTP server
COMPANION_BEARER_TOKEN=change-me-in-production

# Comma-separated list of allowed request origins (leave empty to allow all)
COMPANION_ALLOWED_ORIGINS=http://localhost:8888,https://example.com

# HTTP port for the companion MCP server (stdio is always available)
PORT=3500

# Remote MCP server to proxy requests to (optional — leave empty to disable proxy)
MCP_PROXY_TARGET=

# Bearer token for the upstream proxy target
MCP_PROXY_TOKEN=
