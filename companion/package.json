{
	"name": "@stonewright/companion",
	"version": "1.0.0-alpha.62",
	"description": "Node companion for the Stonewright WordPress MCP plugin: WP-CLI, health checks, and optional MCP HTTP proxy.",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cosmincraciun97/stonewright-wp-mcp.git"
	},
	"files": [
		"dist",
		"scripts/postinstall.mjs",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"main": "dist/index.js",
	"bin": {
		"stonewright-companion": "dist/index.js",
		"stonewright-mcp": "dist/index.js"
	},
	"exports": {
		".": "./dist/index.js"
	},
	"overrides": {
		"esbuild": "^0.28.1",
		"js-yaml": "^4.2.0"
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean --outDir dist",
		"build:contracts": "node scripts/build-contracts.mjs",
		"dev": "tsup src/index.ts --format esm --watch --onSuccess \"node dist/index.js\"",
		"start": "node dist/index.js",
		"mcp": "node dist/index.js",
		"mcp:source": "npm run build && node dist/index.js",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src tests --ext .ts",
		"typecheck": "tsc --noEmit",
		"prepack": "npm run build",
		"postinstall": "node scripts/postinstall.mjs"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",
		"dotenv": "^16.4.5",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@emnapi/core": "^1.11.1",
		"@emnapi/runtime": "^1.11.1",
		"@types/node": "^20.14.0",
		"@typescript-eslint/eslint-plugin": "^7.13.0",
		"@typescript-eslint/parser": "^7.13.0",
		"ajv": "^8.20.0",
		"eslint": "^8.57.0",
		"json-schema-to-typescript": "^15.0.4",
		"tsup": "^8.5.1",
		"typescript": "^5.4.5",
		"vitest": "^4.1.9"
	}
}
